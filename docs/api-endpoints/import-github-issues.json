{
  "name": "importGitHubIssues",
  "description": "Import GitHub issues as tasks",
  "method": "POST",
  "path": "/github-integration/import-issues",
  "parameters": [],
  "requestBody": {
    "type": "object",
    "required": ["projectId"],
    "properties": {
      "projectId": { "type": "string" }
    }
  },
  "responses": {
    "200": {
      "type": "object",
      "required": ["imported", "skipped"],
      "properties": {
        "imported": { "type": "number" },
        "skipped": { "type": "number" },
        "errors": { "type": "array", "items": { "type": "string" } }
      }
    }
  },
  "enums": {},
  "tags": ["GitHub"]
}
