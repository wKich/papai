{
  "name": "markNotificationAsRead",
  "description": "Mark a specific notification as read",
  "method": "PATCH",
  "path": "/notification/{id}/read",
  "parameters": [
    {
      "name": "id",
      "in": "path",
      "type": "string",
      "required": true
    }
  ],
  "requestBody": null,
  "responses": {
    "200": {
      "type": "object",
      "required": ["id", "userId", "title", "content", "type", "createdAt"],
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string", "nullable": true },
        "type": {
          "enum": [
            "info",
            "task_created",
            "workspace_created",
            "task_status_changed",
            "task_assignee_changed",
            "time_entry_created"
          ]
        },
        "isRead": { "type": "boolean" },
        "resourceId": { "type": "string" },
        "resourceType": {
          "enum": ["task", "workspace"]
        },
        "createdAt": {}
      }
    }
  },
  "enums": {
    "NotificationType": [
      "info",
      "task_created",
      "workspace_created",
      "task_status_changed",
      "task_assignee_changed",
      "time_entry_created"
    ],
    "ResourceType": ["task", "workspace"]
  },
  "tags": ["Notifications"]
}
