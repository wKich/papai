{
  "name": "updateTimeEntry",
  "description": "Update an existing time entry",
  "method": "PUT",
  "path": "/time-entry/{id}",
  "parameters": [
    {
      "name": "id",
      "in": "path",
      "type": "string",
      "required": true
    }
  ],
  "requestBody": {
    "type": "object",
    "required": ["startTime"],
    "properties": {
      "startTime": { "type": "string" },
      "endTime": { "type": "string" },
      "description": { "type": "string" }
    }
  },
  "responses": {
    "200": {
      "type": "object",
      "required": ["id", "taskId", "userId", "description", "startTime", "duration", "createdAt"],
      "properties": {
        "id": { "type": "string" },
        "taskId": { "type": "string" },
        "userId": { "type": "string", "nullable": true },
        "description": { "type": "string", "nullable": true },
        "startTime": {},
        "endTime": {},
        "duration": { "type": "number", "nullable": true },
        "createdAt": {}
      }
    }
  },
  "enums": {},
  "tags": ["Time Entries"]
}
