{
  "name": "getInvitationDetails",
  "description": "Get details of a specific invitation by ID",
  "method": "GET",
  "path": "/invitation/{id}",
  "parameters": [
    {
      "name": "id",
      "in": "path",
      "type": "string",
      "required": true
    }
  ],
  "requestBody": null,
  "responses": {
    "200": {
      "type": "object",
      "required": ["valid"],
      "properties": {
        "valid": { "type": "boolean" },
        "invitation": {
          "type": "object",
          "required": ["id", "email", "workspaceName", "inviterName", "expiresAt", "status", "expired"],
          "properties": {
            "id": { "type": "string" },
            "email": { "type": "string" },
            "workspaceName": { "type": "string" },
            "inviterName": { "type": "string" },
            "expiresAt": { "type": "string" },
            "status": { "type": "string" },
            "expired": { "type": "boolean" }
          }
        },
        "error": { "type": "string" }
      }
    }
  },
  "enums": {},
  "tags": ["Invitations"]
}
