{
  "name": "verifyGitHubInstallation",
  "description": "Verify GitHub app installation for a repository",
  "method": "POST",
  "path": "/github-integration/verify",
  "parameters": [],
  "requestBody": {
    "type": "object",
    "required": ["repositoryOwner", "repositoryName"],
    "properties": {
      "repositoryOwner": { "type": "string", "minLength": 1 },
      "repositoryName": { "type": "string", "minLength": 1 }
    }
  },
  "responses": {
    "200": {
      "type": "object",
      "required": ["installed"],
      "properties": {
        "installed": { "type": "boolean" },
        "message": { "type": "string" }
      }
    }
  },
  "enums": {},
  "tags": ["GitHub"]
}
