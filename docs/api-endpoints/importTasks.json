{
  "name": "importTasks",
  "description": "Import multiple tasks into a project",
  "method": "POST",
  "path": "/task/import/{projectId}",
  "parameters": [
    {
      "name": "projectId",
      "in": "path",
      "required": true,
      "schema": {
        "type": "string"
      }
    }
  ],
  "requestBody": {
    "required": true,
    "content": {
      "application/json": {
        "schema": {
          "type": "object",
          "properties": {
            "tasks": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "title": {
                    "type": "string"
                  },
                  "description": {
                    "type": "string"
                  },
                  "status": {
                    "type": "string"
                  },
                  "priority": {
                    "type": "string"
                  },
                  "dueDate": {
                    "type": "string"
                  },
                  "userId": {
                    "type": "string",
                    "nullable": true
                  }
                },
                "required": ["title", "status"]
              }
            }
          },
          "required": ["tasks"]
        }
      }
    }
  },
  "responses": {
    "200": {
      "description": "Tasks imported successfully",
      "content": {
        "application/json": {
          "schema": {
            "type": "object"
          }
        }
      }
    }
  },
  "enums": {}
}
