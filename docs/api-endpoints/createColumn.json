{
  "endpoint": "createColumn",
  "description": "Create a new column in a project",
  "httpMethod": "POST",
  "path": "/column/{projectId}",
  "pathParameters": [
    {
      "name": "projectId",
      "in": "path",
      "schema": {
        "type": "string"
      },
      "required": true
    }
  ],
  "requestBody": {
    "required": true,
    "contentType": "application/json",
    "schema": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "icon": {
          "type": "string"
        },
        "color": {
          "type": "string"
        },
        "isFinal": {
          "type": "boolean"
        }
      },
      "required": ["name"]
    }
  },
  "response": {
    "statusCode": 200,
    "description": "Column created successfully",
    "schema": {}
  },
  "enums": {},
  "constants": {},
  "authentication": "bearerAuth"
}
