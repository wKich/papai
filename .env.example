# Telegram Bot token from @BotFather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Your personal Telegram user ID (get it from @userinfobot)
# Only messages from this user will be processed
TELEGRAM_USER_ID=123456789

# Optional: Log level (debug, info, warn, error). Defaults to info.
LOG_LEVEL=info

# Provider credentials are configured at runtime via Telegram /set commands:
#   /set openai_key sk-xxxxxxxxxxxx
#   /set linear_key lin_api_xxxxxxxxxxxx
#   /set linear_team_id your_linear_team_id_here
#   /set openai_base_url https://api.openai.com/v1
#   /set openai_model gpt-4o
# Values are persisted in papai.db (SQLite). Use /config to view current settings.
