# Telegram Bot token from @BotFather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Admin Telegram user ID (get it from @userinfobot)
# This user is auto-authorized on first run and can add/remove other users via /user command
TELEGRAM_USER_ID=123456789

# Optional: Log level (debug, info, warn, error). Defaults to info.
LOG_LEVEL=info

# Huly Configuration (Required)
HULY_URL=https://huly.app
HULY_WORKSPACE=your-workspace

# User-specific config (set via /set command):
# huly_email=user@example.com
# huly_password=secret

# OpenAI Configuration (Required)
# openai_key - Your OpenAI API key (set via /set command)
# openai_base_url - API base URL, defaults to https://api.openai.com/v1
# openai_model - Model to use, defaults to gpt-4o

# Values are persisted in papai.db (SQLite). Use /config to view current settings.
