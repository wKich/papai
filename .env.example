# Telegram Bot token from @BotFather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Your personal Telegram user ID (get it from @userinfobot)
# Only messages from this user will be processed
TELEGRAM_USER_ID=123456789

# Linear API key (Settings → API → Personal API keys)
LINEAR_API_KEY=lin_api_xxxxxxxxxxxx

# Default Linear team ID for issue creation
# Run list_projects in the bot to find your team ID
LINEAR_TEAM_ID=your_linear_team_id_here

# OpenAI API key (platform.openai.com/api-keys)
OPENAI_API_KEY=sk-xxxxxxxxxxxx

# Optional: Log level (debug, info, warn, error). Defaults to info.
LOG_LEVEL=info
