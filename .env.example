# Chat provider: telegram or mattermost
CHAT_PROVIDER=telegram

# Task provider: kaneo or youtrack (determines which task tracker to use)
TASK_PROVIDER=kaneo

# Admin user ID (platform-specific: numeric for Telegram, string for Mattermost)
# This user is auto-authorized on first run and can add/remove other users via /user command
ADMIN_USER_ID=123456789

# --- Telegram-specific (required when CHAT_PROVIDER=telegram) ---
# Bot token from @BotFather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# --- Mattermost-specific (required when CHAT_PROVIDER=mattermost) ---
# MATTERMOST_URL=https://mm.example.com
# MATTERMOST_BOT_TOKEN=your_mattermost_bot_token_here

# Optional: Log level (debug, info, warn, error). Defaults to info.
LOG_LEVEL=info

# --- Task provider specific settings ---

# When TASK_PROVIDER=kaneo:
# Required: Public URL of the Kaneo instance (used by the bot to reach the API and by Caddy for TLS)
# The API is served under <KANEO_CLIENT_URL>/api — no separate API domain needed
KANEO_CLIENT_URL=https://kaneo.example.com

# Internal URL used by the bot to call the Kaneo API directly (bypasses Caddy/TLS).
# Defaults to http://kaneo-api:1337 when running via Docker Compose.
# KANEO_INTERNAL_URL=http://kaneo-api:1337

# When TASK_PROVIDER=youtrack:
# Required: URL of the YouTrack instance
# YOUTRACK_URL=https://youtrack.example.com

# --- Kaneo self-host (docker compose) ---

# Required: PostgreSQL password for Kaneo database
KANEO_POSTGRES_PASSWORD=changeme

# Required: Secret for signing JWT tokens (32+ characters)
KANEO_AUTH_SECRET=change-me-to-a-random-string-at-least-32-chars

# Disable public sign-up on the Kaneo instance (default: true).
# Set to false temporarily when provisioning new accounts, then back to true.
KANEO_DISABLE_REGISTRATION=true

# Demo mode: when true, any user who messages the bot is automatically
# added, Kaneo-provisioned, and pre-filled with the admin's LLM config.
# Intended for demo/evaluation use. Defaults to false.
# DEMO_MODE=false

# Optional: PostgreSQL database name and user (defaults: kaneo)
# KANEO_POSTGRES_DB=kaneo
# KANEO_POSTGRES_USER=kaneo

# Provider credentials are configured at runtime via /set commands:
#   /set kaneo_apikey your_kaneo_api_key_here
#   /set llm_apikey sk-xxxxxxxxxxxx
#   /set llm_baseurl https://api.openai.com/v1
#   /set main_model gpt-4o
#   /set small_model gpt-4o-mini   # optional: model used to extract and summarise memory facts
# Values are persisted in papai.db (SQLite). Use /config to view current settings.
