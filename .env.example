# Telegram Bot token from @BotFather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Admin Telegram user ID (get it from @userinfobot)
# This user is auto-authorized on first run and can add/remove other users via /user command
TELEGRAM_USER_ID=123456789

# Optional: Log level (debug, info, warn, error). Defaults to info.
LOG_LEVEL=info

# --- Kaneo self-host (docker compose) ---

# Required: PostgreSQL password for Kaneo database
KANEO_POSTGRES_PASSWORD=changeme

# Required: Secret for signing JWT tokens (32+ characters)
KANEO_AUTH_SECRET=change-me-to-a-random-string-at-least-32-chars

# Optional: PostgreSQL database name and user (defaults: kaneo)
# KANEO_POSTGRES_DB=kaneo
# KANEO_POSTGRES_USER=kaneo

# Optional: Exposed ports (defaults: API 1337, Web 5173)
# KANEO_API_PORT=1337
# KANEO_WEB_PORT=5173

# Optional: Public URLs (set these when running behind a reverse proxy)
# KANEO_CLIENT_URL=https://kaneo.example.com
# KANEO_API_URL=https://kaneo-api.example.com

# Provider credentials are configured at runtime via Telegram /set commands:
#   /set openai_key sk-xxxxxxxxxxxx
#   /set openai_base_url https://api.openai.com/v1
#   /set openai_model gpt-4o
#   /set kaneo_key your_kaneo_api_key_here
#   /set kaneo_base_url https://your-kaneo-instance.com
#   /set kaneo_workspace_id your_workspace_id_here
#   /set kaneo_project_id your_default_project_id_here
# Values are persisted in papai.db (SQLite). Use /config to view current settings.
