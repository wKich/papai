{
  "testRunner": "bun",
  "appendPlugins": ["@hughescr/stryker-bun-runner"],
  "checkers": ["typescript"],
  "tsconfigFile": "tsconfig.json",
  "bun": {
    "timeout": 120000
  },
  "mutate": [
    "src/providers/**/*.ts",
    "!src/providers/**/index.ts",
    "!src/providers/**/constants.ts",
    "!src/providers/types.ts",
    "src/tools/**/*.ts",
    "!src/tools/index.ts",
    "src/errors.ts",
    "src/config.ts",
    "src/memory.ts",
    "src/users.ts",
    "src/cron.ts",
    "src/recurring.ts",
    "src/history.ts",
    "src/conversation.ts"
  ],
  "coverageAnalysis": "perTest",
  "ignoreStatic": true,
  "incremental": true,
  "incrementalFile": "reports/stryker-incremental.json",
  "concurrency": 8,
  "timeoutMS": 60000,
  "timeoutFactor": 2,
  "thresholds": {
    "high": 80,
    "low": 60,
    "break": 40
  },
  "reporters": ["clear-text", "progress", "html", "json"],
  "htmlReporter": {
    "fileName": "reports/mutation.html"
  },
  "jsonReporter": {
    "fileName": "reports/mutation.json"
  },
  "ignorePatterns": ["node_modules", ".stryker-tmp"],
  "cleanTempDir": true
}
