{
  "name": "papai",
  "private": true,
  "description": "papai — an intelligent Telegram bot for managing Linear tasks with LLM.",
  "type": "module",
  "module": "src/index.ts",
  "scripts": {
    "start": "bun run src/index.ts",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "prepare": "cp scripts/pre-commit.sh .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.39",
    "@linear/sdk": "^76.0.0",
    "ai": "^6.0.108",
    "grammy": "^1.41.1",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "oxfmt": "^0.36.0",
    "oxlint": "latest",
    "typescript": "latest"
  }
}
