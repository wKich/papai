{
  "name": "papai",
  "version": "3.2.0",
  "private": true,
  "description": "papai — an intelligent Telegram bot for managing Kaneo tasks with LLM.",
  "type": "module",
  "module": "src/index.ts",
  "scripts": {
    "start": "bun run src/index.ts",
    "knip": "knip-bun --strict",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "format": "oxfmt --write . --ignore-path=.oxfmtignore",
    "format:check": "oxfmt --check . --ignore-path=.oxfmtignore",
    "security": "bun run scripts/run-semgrep.ts",
    "security:ci": "bun run scripts/run-semgrep.ts --ci",
    "test": "bun test tests/providers tests/tools tests/scripts tests/db tests/utils tests/schemas tests/*.test.ts",
    "test:watch": "bun test tests/providers tests/tools tests/scripts tests/db tests/utils tests/schemas tests/*.test.ts --watch",
    "test:coverage": "bun test tests/providers tests/tools tests/scripts tests/db tests/utils tests/schemas tests/*.test.ts --coverage",
    "test:e2e": "bun test --preload ./tests/e2e/bun-test-setup.ts tests/e2e/e2e.test.ts",
    "test:e2e:watch": "bun test --preload ./tests/e2e/bun-test-setup.ts tests/e2e/e2e.test.ts --watch",
    "prepare": "[ -d .git ] && cp scripts/pre-commit.sh .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit || true",
    "changelog:preview": "git-cliff --dry-run",
    "changelog:generate": "git-cliff -o CHANGELOG.md",
    "migrate:linear": "bun run src/scripts/migrate-linear-to-kaneo.ts",
    "migrate:kaneo": "bash scripts/migrate-to-kaneo.sh",
    "test:migration": "bun run src/scripts/test-migration.ts"
  },
  "dependencies": {
    "@ai-sdk/openai-compatible": "^2.0.35",
    "@ai-sdk/provider": "^3.0.8",
    "@gramio/format": "^0.6.0",
    "ai": "^6.0.116",
    "grammy": "^1.41.1",
    "marked": "^17.0.4",
    "pino": "^10.3.1",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@gramio/types": "^9.5.0",
    "@grammyjs/types": "^3.25.0",
    "@types/bun": "1.3.11",
    "knip": "^5.88.0",
    "oxfmt": "^0.41.0",
    "oxlint": "1.56.0",
    "oxlint-tsgolint": "^0.17.0",
    "typescript": "latest"
  }
}
