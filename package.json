{
  "name": "papai",
  "version": "5.1.3",
  "private": true,
  "description": "papai — an intelligent Telegram bot for managing Kaneo tasks with LLM.",
  "workspaces": [
    "codeindex",
    "review-loop"
  ],
  "type": "module",
  "module": "src/index.ts",
  "scripts": {
    "build:client": "bun scripts/build-client.ts",
    "start": "bun build:client && bun run src/index.ts",
    "start:debug": "bun build:client && DEBUG_SERVER=true bun run src/index.ts",
    "review-loop:test": "bun run --filter review-loop test",
    "review-loop:typecheck": "bun run --filter review-loop typecheck",
    "review-loop:lint": "bun run --filter review-loop lint",
    "review-loop:format:check": "bun run --filter review-loop format:check",
    "review-loop:start": "bun run --filter review-loop start",
    "knip": "knip-bun --strict --no-gitignore",
    "typecheck": "tsgo --noEmit",
    "lint": "oxlint --config .oxlintrc.json .",
    "lint:agent-strict": "bash scripts/lint-agent-strict.sh",
    "lint:fix": "oxlint --config .oxlintrc.json --fix .",
    "format": "oxfmt --write . --ignore-path=.oxfmtignore",
    "format:check": "oxfmt --check . --ignore-path=.oxfmtignore",
    "security": "bun run scripts/run-semgrep.ts",
    "security:ci": "bun run scripts/run-semgrep.ts --ci",
    "test": "bun test tests/providers tests/tools tests/web tests/db tests/utils tests/schemas tests/proactive tests/debug tests/*.test.ts",
    "test:client": "bun test --preload ./tests/client-setup.ts --path-ignore-patterns '' tests/client/",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test --coverage",
    "test:mutate": "stryker run",
    "test:mutate:changed": "stryker run --incremental",
    "test:mutate:full": "stryker run --force",
    "test:e2e": "bun test --preload ./tests/e2e/bun-test-setup.ts --path-ignore-patterns '' tests/e2e/e2e.test.ts",
    "test:e2e:watch": "bun test --preload ./tests/e2e/bun-test-setup.ts --path-ignore-patterns '' tests/e2e/e2e.test.ts --watch",
    "check": "./scripts/check.sh --staged",
    "check:full": "./scripts/check.sh",
    "check:verbose": "bun run --parallel lint typecheck format:check knip test duplicates codeindex:lint codeindex:typecheck codeindex:format:check codeindex:test review-loop:lint review-loop:typecheck review-loop:format:check review-loop:test",
    "fix": "bun run lint:fix && bun run format",
    "duplicates": "bun run scripts/detect-duplicates.ts",
    "prepare": "[ -d .git ] && cp scripts/pre-commit.sh .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit || true",
    "changelog:preview": "git-cliff --dry-run",
    "changelog:generate": "git-cliff -o CHANGELOG.md",
    "audit:behavior": "bun scripts/behavior-audit.ts",
    "plan-adr-workflow": "bun scripts/plan-adr-workflow.ts",
    "codeindex:test": "bun run --filter codeindex test",
    "codeindex:typecheck": "bun run --filter codeindex typecheck",
    "codeindex:lint": "bun run --filter codeindex lint",
    "codeindex:format:check": "bun run --filter codeindex format:check"
  },
  "dependencies": {
    "@ai-sdk/openai-compatible": "^2.0.41",
    "@ai-sdk/provider": "^3.0.8",
    "@gramio/format": "^0.7.0",
    "ai": "^6.0.154",
    "ai-tokenizer": "^1.0.6",
    "date-fns-tz": "^3.2.0",
    "defuddle": "^0.18.1",
    "discord.js": "^14.25.1",
    "drizzle-orm": "^0.45.2",
    "fuse.js": "^7.3.0",
    "grammy": "^1.42.0",
    "ipaddr.js": "^2.3.0",
    "linkedom": "^0.18.12",
    "marked": "^18.0.0",
    "p-limit": "^7.3.0",
    "pino": "^10.3.1",
    "rrule-temporal": "^1.5.2",
    "unpdf": "^1.4.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@gramio/types": "^9.6.0",
    "@grammyjs/types": "^3.26.0",
    "@happy-dom/global-registrator": "^20.8.9",
    "@hughescr/stryker-bun-runner": "^1.2.1",
    "@opencode-ai/sdk": "^1.14.24",
    "@stryker-mutator/core": "^9.6.0",
    "@stryker-mutator/typescript-checker": "^9.6.0",
    "@types/bun": "1.3.13",
    "@typescript/native-preview": "^7.0.0-dev.20260424.2",
    "drizzle-kit": "^0.31.10",
    "happy-dom": "^20.8.9",
    "jscpd": "^4.0.8",
    "knip": "^6.6.3",
    "oxfmt": "^0.46.0",
    "oxlint": "1.61.0",
    "oxlint-tsgolint": "^0.21.1",
    "typescript": "^6.0.0"
  },
  "overrides": {
    "typescript": "$typescript"
  }
}
