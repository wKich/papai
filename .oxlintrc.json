{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript", "vitest"],
  "jsPlugins": ["./lint-plugins/papai-policy.js"],
  "ignorePatterns": ["docs/tdd-hooks/**", ".hooks/**", ".opencode/**", ".claude/hooks/**", "lint-plugins/**"],
  "categories": {
    "correctness": "error",
    "suspicious": "error",
    "pedantic": "error",
    "perf": "error"
  },
  "options": {
    "typeAware": true,
    "typeCheck": true,
    "denyWarnings": true
  },
  "rules": {
    "vitest/expect-expect": "error",
    "vitest/valid-expect": "error",
    "vitest/no-conditional-tests": "error",
    "vitest/no-conditional-expect": "error",
    "vitest/no-disabled-tests": "error",
    "vitest/no-focused-tests": "error",
    "vitest/require-local-test-context-for-concurrent-snapshots": "error",
    "typescript/explicit-function-return-type": "error",
    "typescript/explicit-module-boundary-types": "error",
    "typescript/no-dynamic-delete": "error",
    "typescript/no-empty-object-type": "error",
    "typescript/no-explicit-any": "error",
    "typescript/no-invalid-void-type": "error",
    "typescript/no-import-type-side-effects": "error",
    "typescript/no-namespace": "error",
    "typescript/no-require-imports": "error",
    "typescript/no-restricted-types": "error",
    "typescript/no-var-requires": "error",
    "typescript/no-wrapper-object-types": "error",
    "typescript/non-nullable-type-assertion-style": "error",
    "typescript/prefer-literal-enum-member": "error",
    "typescript/promise-function-async": "off",
    "typescript/use-unknown-in-catch-callback-variable": "error",
    "eslint/no-empty": "error",
    "eslint/no-empty-function": "error",
    "eslint/no-param-reassign": "error",
    "import/extensions": ["error", "always", { "ignorePackages": true }],
    "import/no-cycle": "error",
    "oxc/no-barrel-file": "error",
    "oxc/no-optional-chaining": "error",
    "node/no-path-concat": "error",
    "promise/catch-or-return": "error",
    "unicorn/no-abusive-eslint-disable": "error",
    "papai-policy/no-inline-suppression-comments": "error",
    "papai-policy/no-optional-type-syntax": "off",
    "papai-policy/no-default-value-syntax": "off",
    "papai-policy/no-fallback-expressions": "off",
    "typescript/prefer-readonly-parameter-types": "off"
  },
  "overrides": [
    {
      "files": ["tests/**/*.ts"],
      "rules": {
        "max-lines-per-function": "off",
        "max-lines": "off",
        "no-await-in-loop": "off",
        "typescript/no-confusing-void-expression": "off",
        "typescript/await-thenable": "off",
        "eslint/no-empty-function": "off"
      }
    }
  ]
}
