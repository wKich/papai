{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/session-start.mjs",
            "timeout": 600,
            "statusMessage": "Capturing session mutation baseline..."
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/pre-tool-use.mjs",
            "timeout": 200,
            "statusMessage": "TDD checks (pre-edit)..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/post-tool-use.mjs",
            "timeout": 200,
            "statusMessage": "TDD checks (post-edit)..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/session-stop.mjs",
            "timeout": 600,
            "statusMessage": "Running session-level mutation tests..."
          }
        ]
      }
    ]
  }
}
