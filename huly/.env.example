DOCKER_NAME=huly
HULY_VERSION=v0.6.295

# Public domain (Caddy will provision TLS automatically)
HOST_ADDRESS=huly.example.com

# Shared secret — generate with: openssl rand -hex 32
SECRET=change-me

# CockroachDB
CR_DATABASE=huly
CR_USERNAME=root
CR_USER_PASSWORD=
CR_DB_URL=postgresql://root@cockroach:26257/huly?sslmode=disable

# Redpanda
REDPANDA_ADMIN_USER=admin
REDPANDA_ADMIN_PWD=change-me

# Optional
TITLE=Huly Self Host
DEFAULT_LANGUAGE=en
LAST_NAME_FIRST=true
DESKTOP_CHANNEL=

# Custom volume paths (leave empty to use named Docker volumes)
VOLUME_ELASTIC_PATH=
VOLUME_FILES_PATH=
VOLUME_CR_DATA_PATH=
VOLUME_CR_CERTS_PATH=
VOLUME_REDPANDA_PATH=
